---
import { siteConfig } from "../utils/site";
import type { TocItem } from "../utils/toc";

type Props = {
  items: TocItem[];
  locale?: "ja" | "en";
  affiliation?: string;
};

const {
  items,
  locale = "ja",
  affiliation = siteConfig.affiliation,
} = Astro.props;

const isEnglish = locale === "en";
const [nameMain, nameSub] = locale === "ja"
  ? [siteConfig.nameJa, siteConfig.nameEn]
  : [siteConfig.nameEn, siteConfig.nameJa];
const affiliationLabel = isEnglish ? "Affiliation" : "所属";
---

<header>
  <div class="name-stack">
    <div class="heading-row">
      <h1>{nameMain}</h1>
      <p class="secondary-name">{nameSub}</p>
      <p class="locale-switch" aria-label="Language switcher">
        <a href="/" aria-current={isEnglish ? undefined : "page"}>JP</a>
        <span aria-hidden="true"> | </span>
        <a href="/en/" aria-current={isEnglish ? "page" : undefined}>EN</a>
      </p>
    </div>
  </div>
  <p>
    <span>{affiliationLabel}: </span>
    <span class="label">{affiliation}</span>
  </p>
  <p>
    <span>Email: </span>
    <span class="label">{siteConfig.email}</span>
    <button
      id="email-copy-button"
      class="copy-button"
      type="button"
      aria-label="Copy email address"
      data-email={siteConfig.email}
    >
      ⧉
    </button>
    <span id="email-copy-status" class="copy-status" aria-live="polite"></span>
  </p>
  <nav aria-label="Section navigation">
    <ul>
      {items.map((item) => (
        <li>
          <a href={`#${item.id}`}>{item.text}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const emailCopyButton = document.getElementById("email-copy-button");
  const emailCopyStatus = document.getElementById("email-copy-status");
  let emailCopyStatusTimer;

  emailCopyButton?.addEventListener("click", async () => {
    const email = emailCopyButton.getAttribute("data-email")?.replace("(at)", "@");
    if (!email) return;

    await navigator.clipboard.writeText(email);
    if (!emailCopyStatus) return;

    emailCopyStatus.textContent = "Copied";
    clearTimeout(emailCopyStatusTimer);
    emailCopyStatusTimer = window.setTimeout(() => {
      emailCopyStatus.textContent = "";
    }, 1600);
  });
</script>

<style>
header {
  margin: 0 auto 50px;
}

.heading-row {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 16px;
}

.name-stack {
  margin-bottom: 20px;
}

h1 {
  display: inline-block;
  margin: 0;
  line-height: 1;
  white-space: nowrap;
  font-weight: 400;
}

.secondary-name {
  margin: 0;
  line-height: 1;
}

p {
  margin: 0;
  word-break: keep-all;
  overflow-wrap: normal;
}

.copy-button {
  margin-left: 0.4em;
  padding: 0;
  border: 0;
  background: transparent;
  color: inherit;
  font: inherit;
  line-height: 1;
  cursor: pointer;
}

.copy-status {
  display: inline-block;
  min-width: 4.5em;
  margin-left: 0.4em;
  font-size: 0.9em;
}

.locale-switch {
  margin-left: auto;
  flex-shrink: 0;
  white-space: nowrap;
}

.locale-switch a[aria-current="page"] {
  font-weight: 700;
  text-decoration: none;
}

@media (max-width: 640px) {
  .heading-row {
    gap: 8px 16px;
  }
}
</style>
